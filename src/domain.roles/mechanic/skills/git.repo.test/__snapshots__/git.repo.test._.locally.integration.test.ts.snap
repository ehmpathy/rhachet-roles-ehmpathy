// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`git.repo.test --locally given: [case1] --locally with test:acceptance:locally present when: [t0] --what acceptance --locally is run then: output matches snapshot 1`] = `
"🐢 lets ride...

🐚 git.repo.test --what acceptance --mode apply --locally
   ├─ keyrack: unlocked ehmpath/test
   ├─ status
   │  ├─ 💤 inflight (Xs)
   │  └─ 🎉 passed (Xs)
   └─ log
      ├─ omitted on success by default
      └─ hint: use \`--log always\` to persist when desired
"
`;

exports[`git.repo.test --locally given: [case2] --locally with test:acceptance:locally absent when: [t0] --what acceptance --locally is run but command absent then: output matches snapshot 1`] = `
"🐢 bummer dude...

🐚 git.repo.test --what acceptance --locally
   ├─ status: constraint
   └─ error: no 'test:acceptance:locally' command in package.json

hint: ehmpathy convention uses 'test:lint', 'test:unit', 'test:integration', 'test:acceptance'
"
`;

exports[`git.repo.test --locally given: [case3] --locally used with non-acceptance test type when: [t0] --what unit --locally is run then: output matches snapshot 1`] = `
"🐢 bummer dude...

🐚 git.repo.test --what unit --locally
   └─ error: --locally only valid with --what acceptance

usage: git.repo.test.sh --what acceptance --locally
"
`;
