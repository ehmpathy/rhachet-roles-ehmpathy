// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`git.repo.test --against given: [case1] --against local with test:acceptance:locally present when: [t0] --what acceptance --against local --env test is run then: output matches snapshot 1`] = `
"🐢 lets ride...

🐚 git.repo.test --what acceptance --mode apply --against local --env test
   ├─ keyrack: unlocked ehmpath/test
   ├─ status
   │  ├─ 💤 inflight (Xs)
   │  └─ 🎉 passed (Xs)
   └─ log
      ├─ omitted on success by default
      └─ hint: use \`--log always\` to persist when desired
"
`;

