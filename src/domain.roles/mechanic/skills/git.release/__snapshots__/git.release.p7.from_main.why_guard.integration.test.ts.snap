// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`git.release.p7.from_main.why_guard given: [case1] non-human on a feature branch, --from main, no --why when: [t0] rhx git.release --from main --into prod then: blocks with exit 2 and steers to --into prod 1`] = `
"🐢 hold up dude...

🐚 git.release --from main --into prod
   └─ ✋ blocked: --from main needs a --why

   you're on a feature branch. --from main skips your branch and
   releases whatever is already on main — often the stale prior release.

   ➤ if you just want to ship your work, that's safer:
     rhx git.release --into prod

   ➤ if you really need --from main (hotfix, recovery), say why:
     rhx git.release --from main --into prod --why "<reason>"
"
`;

exports[`git.release.p7.from_main.why_guard given: [case2] non-human on a feature branch, --from main, --why "reason" when: [t0] rhx git.release --from main --into prod --why "<reason>" then: allows the release (not blocked) 1`] = `
"🐢 heres the wave...

🐚 git.release --into prod --mode plan

🌊 release: chore(release): v1.3.0
   ├─ 👌 all checks passed
   └─ 🌴 already merged

🫧 and then...

🌊 release: v1.3.0
   └─ 👌 all checks passed
"
`;

