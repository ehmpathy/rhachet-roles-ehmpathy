exports[`globsafe.sh given: [case14] bracket characters with --literal flag when: [t3] brackets used without --literal and no match then: shows did-you-know hint 1`] = `
"🐢 crickets...

🐚 globsafe
   ├─ pattern: doc.[ref].md
   ├─ path: .
   └─ files: 0

🥥 did you know?
   ├─ pattern contains \`[\` which is a glob character
   ├─ to treat \`[\` as literal, use either:
   │  ├─ --literal flag: rhx globsafe --pattern 'doc.[ref].md' --literal
   │  └─ escape syntax: rhx globsafe --pattern 'doc.\\[ref\\].md'
   └─ see: rhx globsafe --help
"
`;

