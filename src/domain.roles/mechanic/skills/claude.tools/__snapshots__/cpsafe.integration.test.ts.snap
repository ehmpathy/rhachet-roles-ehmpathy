exports[`cpsafe.sh given: [case3] argument validation when: [t3] --help flag then: shows usage info and exits 0 1`] = `
"usage: cpsafe.sh <from> <into>
       cpsafe.sh --from <source> --into <destination>
       cpsafe.sh --literal <from> <into>

options:
  --from <path>    source path or glob pattern
  --into <path>    destination path
  --literal, -l    treat path as literal (no glob expansion)
                   use when path contains [ or ] characters

examples:
  cpsafe.sh 'src/*.ts' 'dest/'              # glob pattern
  cpsafe.sh --literal 'file.[ref].md' 'new.[ref].md'  # literal brackets
  cpsafe.sh 'file.\\[ref\\].md' 'new.\\[ref\\].md'      # escaped brackets
"
`;

